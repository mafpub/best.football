# Python
__pycache__/
*.py[cod]
.venv/

# Data (regenerated from sources)
data/cache/
data/*.db

# Generated site (built from database)
htdocs/schools/
htdocs/regions/
htdocs/search/
htdocs/index.html
htdocs/sitemap.xml

# Generated camp/guide/ranking detail pages
htdocs/camps/*.html
htdocs/guides/*.html
htdocs/rankings/*/*.html

# Keep static assets and hand-crafted index pages
!htdocs/includes/
!htdocs/css/
!htdocs/js/
!htdocs/favicon.svg
!htdocs/camps/index.html
!htdocs/camps/submit.html
!htdocs/guides/index.html
!htdocs/rankings/index.html

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
